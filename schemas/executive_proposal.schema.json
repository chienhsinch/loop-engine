{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Loop Engine executive proposal",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "decision_type": {
      "type": "string",
      "enum": ["continue", "success", "stop", "human_escalation"]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "supporting_evidence_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "objective": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "outcome": {
              "type": "string",
              "minLength": 1
            },
            "rationale": {
              "type": "string",
              "minLength": 1
            },
            "constraints": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "acceptance_criteria": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "expected_evidence": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "required": [
            "outcome",
            "rationale",
            "constraints",
            "acceptance_criteria",
            "expected_evidence"
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "human_escalation": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "question": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "evidence_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "options": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "required": ["question", "reason", "evidence_ids", "options"]
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "decision_type",
    "rationale",
    "supporting_evidence_ids",
    "objective",
    "human_escalation"
  ]
}
